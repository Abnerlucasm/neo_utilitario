{
  "name": "neohub",
  "version": "1.0.0",
  "description": "Plataforma integrada de colaboração e gerenciamento para a equipe Neo",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node scripts/build-development.js && node server.js",
    "build": "node scripts/build-production.js",
    "build:dev": "node scripts/build-development.js",
    "build:prod": "node scripts/build-production.js",
    "serve:dev": "node scripts/build-development.js && pm2 start scripts/ecosystem.config.js --env development",
    "serve:prod": "node scripts/build-production.js && pm2 start scripts/ecosystem.config.js --env production",
    "deploy": "npm run build:prod && pm2 restart neodeploy",
    "deploy:auto": "./scripts/deploy.sh",
    "logs": "pm2 logs neodeploy",
    "status": "pm2 status",
    "stop": "pm2 stop neodeploy",
    "restart": "pm2 restart neodeploy"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.7.4",
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "dotenv": "^17.4.1",
    "express": "^4.18.2",
    "express-session": "^1.18.1",
    "form-data": "^4.0.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide": "^1.7.0",
    "multer": "^2.1.1",
    "node-fetch": "^3.3.2",
    "node-ssh": "^13.2.0",
    "nodemailer": "^8.0.4",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "pg": "^8.13.3",
    "qrcode": "^1.5.4",
    "sequelize": "^6.37.5",
    "speakeasy": "^2.0.0",
    "ssh2": "^1.16.0",
    "turndown": "^7.2.4",
    "umzug": "^3.7.2",
    "uuid": "^13.0.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.20.0",
    "xml2js": "^0.6.2"
  },
  "keywords": [
    "pwa",
    "dashboard",
    "management",
    "collaboration"
  ],
  "author": "Neo Team",
  "license": "MIT",
  "engines": {
    "node": ">=14.0.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "daisyui": "^5.5.19",
    "pm2": "^6.0.14",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2"
  }
}
